# ============================================================
# D2HA – Docker2HomeAssistant – Environment Configuration
# ============================================================
# COPY this file to .env and change ALL values before deploying.
# NEVER commit the .env file to version control.
# ============================================================

# Flask secret key – MUST be changed to a strong random value.
# Generate one with:  python3 -c "import secrets; print(secrets.token_hex(32))"
# If left empty, a random key is generated on each restart (sessions will be invalidated).
D2HA_SECRET_KEY=

# Initial admin username (password defaults to "admin", change at first login)
D2HA_ADMIN_USERNAME=admin

# Persistent auth config path (used in docker-compose volume mapping)
D2HA_AUTH_CONFIG_PATH=/app/data/auth_config.json

# ---- MQTT Configuration (optional) ----
# Leave MQTT_BROKER empty to disable MQTT integration.
MQTT_BROKER=
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=d2ha_server
MQTT_DISCOVERY_PREFIX=homeassistant
MQTT_NODE_ID=d2ha_server
MQTT_STATE_INTERVAL=5
